# ============================================
# portfolio-v4 · Matteo Dante cockpit
# ============================================
# Copy: cp .env.example .env.local
# ============================================

# Public base URL (SEO canonical, sitemap)
# Dev: http://localhost:3000
# Prod: https://matteodante.it
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ============================================
# OPENAI · Required for COMM chat module
# ============================================
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# ============================================
# UPSTASH REDIS · Optional — cross-instance rate limiting for /api/chat.
# Auto-provisioned if you install Upstash Redis from the Vercel Marketplace.
# When unset, the route falls back to per-instance in-memory rate limiting.
# ============================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ============================================
# CV ACCESS · Gate the full CV / chat / translations / llms.txt
# behind a shared access code. Required.
# - CV_ACCESS_PASSWORD: the access code shared with recruiters
# - CV_ACCESS_SECRET:   long random string used to HMAC-sign the
#   access cookie. Generate: openssl rand -base64 64
# - CV_DECRYPT_KEY:     32-byte AES-256-GCM key (base64) used to
#   decrypt the .enc blobs committed to the repo (private CV, full
#   translations, full chat profile, full llms.txt body).
#   Generate: openssl rand -base64 32
# ============================================
CV_ACCESS_PASSWORD=""
CV_ACCESS_SECRET=""
CV_DECRYPT_KEY=""
