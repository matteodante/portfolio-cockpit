# ============================================
# portfolio-v4 · Matteo Dante cockpit
# ============================================
# Copy: cp .env.example .env.local
# ============================================

# Public base URL (SEO canonical, sitemap)
# Dev: http://localhost:3000
# Prod: https://matteodante.it
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# ============================================
# OPENAI · Required for COMM chat module
# ============================================
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# ============================================
# UPSTASH REDIS · Optional — cross-instance rate limiting for /api/chat.
# Auto-provisioned if you install Upstash Redis from the Vercel Marketplace.
# When unset, the route falls back to per-instance in-memory rate limiting.
# ============================================
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
