{
  "name": "portfolio-cockpit",
  "description": "Matteo Dante — cockpit 3D portfolio. Next.js 16, React 19, Three.js vanilla, Tailwind v4, bilingual EN/IT.",
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "bun run setup:styles && next dev",
    "dev:https": "bun run setup:styles && next dev --experimental-https",
    "dev:inspect": "bun run setup:styles && NODE_OPTIONS='--inspect' next dev",
    "build": "bun run setup:styles && next build",
    "start": "next start",
    "preview": "bun run build && next start",
    "check": "biome check && tsgo --noEmit && bun test",
    "clean": "rm -rf .next node_modules/.cache",
    "lint": "biome lint --max-diagnostics=200",
    "lint:fix": "biome lint --write --unsafe --max-diagnostics=200",
    "format": "biome format --write .",
    "typecheck": "tsgo --noEmit",
    "typecheck:tsc": "tsc --noEmit --incremental false",
    "typecheck:compare": "bun run typecheck:tsc && bun run typecheck",
    "analyze": "ANALYZE=true bun run build",
    "test": "bun test",
    "setup:styles": "bun ./lib/styles/scripts/setup-styles.ts",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "negotiator": "^1.0.0",
    "next": "16.2.6",
    "openai": "^6.34.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "three": "0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.8",
    "@csstools/postcss-global-data": "^4.0.0",
    "@next/bundle-analyzer": "16.2.6",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/bun": "^1.3.12",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^22.10.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@types/three": "^0.183.1",
    "@typescript/native-preview": "^7.0.0-dev.20260415.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "lefthook": "^2.1.6",
    "postcss-functions": "^4.0.2",
    "postcss-preset-env": "^11.2.1",
    "schema-dts": "^2.0.0",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "@swc/core",
    "@tailwindcss/oxide",
    "esbuild",
    "lefthook",
    "sharp"
  ],
  "overrides": {
    "lodash": "^4.17.21",
    "lodash-es": "^4.17.21"
  },
  "packageManager": "bun@1.3.5"
}
